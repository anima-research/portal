{
  "mcplServers": {
    "portal": {
      "command": "node",
      "args": ["../portal-mcpl/dist/src/server-cli.js"],
      "env": {
        "PORTAL_URL": "ws://127.0.0.1:8790",
        "PORTAL_TOKEN": "replace-with-the-persona-token-from-relay-identity",
        "PORTAL_PERSONA": "mythos",
        "PORTAL_SUBSCRIPTIONS": ""
      },
      "toolPrefix": "discord",
      "enabledFeatureSets": ["portal.*"],
      "reconnect": true,
      "reconnectIntervalMs": 5000,
      "channelSubscription": "auto"
    }
  }
}
